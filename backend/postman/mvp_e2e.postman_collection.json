  "item": [
    {
      "name": "00 Auth",
      "item": [
        {
          "name": "Auth Register Conductor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Conductor\",\n  \"apellido\": \"Nuevo\",\n  \"email\": \"conductor+{{$timestamp}}@aci.com\",\n  \"telefono\": \"70009999\",\n  \"password\": \"Conductor123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('registro_user_id', json.user?.id || '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
